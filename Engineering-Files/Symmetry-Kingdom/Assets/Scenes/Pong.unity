  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 159705335}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a6e4ed73e84061f47805fcf0826fde24, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroUI
  introPanel: {fileID: 1356949471}
  introText: {fileID: 163086485}
  storyText: "In the Kingdom of Symmetry, every match was flawless.\nThe ball obeyed
    its angles.\nForce grew in perfect proportion.\nUp was always up.\nPeople believed
    this was the law of nature.\nThey had never seen the one who wrote the rules.\nUntil
    one day, the King spoke \u2014\nThe ball no longer bounced, it fell.\nSome called
    it an accident.\nBut then another decree:\nUp became down.\nThe harder you pushed,
    the slower you moved.\nDoubt began to spread.\nPerhaps the world had never run
    on its own.\nPerhaps rules were never natural \u2014 only maintained by power."
  onIntroFinished:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 1759175331}
        m_TargetAssemblyTypeName: GameUI, Assembly-CSharp
        m_MethodName: OnStartGameButtonClicked
        m_Mode: 1
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
